{
  "swagger": "2.0",
  "info": {
    "title": "Expense Tracker API",
    "description": "REST API for user authentication, expense management, and expense summaries.",
    "version": "1.0.0"
  },
  "host": "localhost:8080",
  "basePath": "/api/v1",
  "schemes": ["http"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "tags": [
    {
      "name": "Health",
      "description": "System status endpoints"
    },
    {
      "name": "Authentication",
      "description": "User registration and login"
    },
    {
      "name": "Expenses",
      "description": "Expense CRUD, filtering, and summaries"
    }
  ],
  "securityDefinitions": {
    "UserIDHeader": {
      "type": "apiKey",
      "name": "X-User-ID",
      "in": "header",
      "description": "User ID returned by the login endpoint. Required for expense endpoints."
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Check API health",
        "description": "Returns a simple success response when the API server is running.",
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "description": "Server is running",
            "schema": {
              "$ref": "#/definitions/EmptyAPIResponse"
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register a user",
        "description": "Creates a new user account with name, email, and password.",
        "operationId": "registerUser",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/RegisterRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "User registered successfully",
            "schema": {
              "$ref": "#/definitions/EmptyAPIResponse"
            }
          },
          "400": {
            "description": "Invalid input",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "409": {
            "description": "Email already exists",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "500": {
            "description": "Registration failed",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Login a user",
        "description": "Authenticates a user and returns the user identity data used by this API.",
        "operationId": "loginUser",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/LoginRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Login successful",
            "schema": {
              "$ref": "#/definitions/LoginResponse"
            }
          },
          "400": {
            "description": "Invalid request body",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "401": {
            "description": "Invalid email or password",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    },
    "/expenses": {
      "get": {
        "tags": ["Expenses"],
        "summary": "List expenses",
        "description": "Returns expenses for the authenticated user. Results can be filtered, sorted, and limited.",
        "operationId": "listExpenses",
        "security": [
          {
            "UserIDHeader": []
          }
        ],
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "type": "string",
            "enum": ["Food", "Transport", "Housing", "Entertainment", "Shopping", "Healthcare", "Education", "Utilities", "Other"]
          },
          {
            "name": "date_from",
            "in": "query",
            "type": "string",
            "format": "date"
          },
          {
            "name": "date_to",
            "in": "query",
            "type": "string",
            "format": "date"
          },
          {
            "name": "sort_by",
            "in": "query",
            "type": "string",
            "enum": ["expense_date", "amount"]
          },
          {
            "name": "sort_order",
            "in": "query",
            "type": "string",
            "enum": ["asc", "desc"]
          },
          {
            "name": "limit",
            "in": "query",
            "type": "integer",
            "minimum": 1
          }
        ],
        "responses": {
          "200": {
            "description": "Expenses retrieved",
            "schema": {
              "$ref": "#/definitions/ExpenseListResponse"
            }
          },
          "400": {
            "description": "Invalid query parameter",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "401": {
            "description": "Missing or invalid X-User-ID header",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "500": {
            "description": "Expenses could not be loaded",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      },
      "post": {
        "tags": ["Expenses"],
        "summary": "Create an expense",
        "description": "Creates an expense for the authenticated user.",
        "operationId": "createExpense",
        "security": [
          {
            "UserIDHeader": []
          }
        ],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ExpenseRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Expense created successfully",
            "schema": {
              "$ref": "#/definitions/ExpenseResponse"
            }
          },
          "400": {
            "description": "Invalid input",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "401": {
            "description": "Missing or invalid X-User-ID header",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "500": {
            "description": "Expense could not be created",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    },
    "/expenses/summary": {
      "get": {
        "tags": ["Expenses"],
        "summary": "Get expense summary",
        "description": "Returns total spending, count, and totals by category for the authenticated user.",
        "operationId": "getExpenseSummary",
        "security": [
          {
            "UserIDHeader": []
          }
        ],
        "parameters": [
          {
            "name": "date_from",
            "in": "query",
            "type": "string",
            "format": "date"
          },
          {
            "name": "date_to",
            "in": "query",
            "type": "string",
            "format": "date"
          }
        ],
        "responses": {
          "200": {
            "description": "Summary generated",
            "schema": {
              "$ref": "#/definitions/ExpenseSummaryResponse"
            }
          },
          "400": {
            "description": "Invalid date range",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "401": {
            "description": "Missing or invalid X-User-ID header",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "500": {
            "description": "Summary could not be generated",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    },
    "/expenses/{id}": {
      "get": {
        "tags": ["Expenses"],
        "summary": "Get an expense",
        "description": "Returns one expense when it belongs to the authenticated user.",
        "operationId": "getExpense",
        "security": [
          {
            "UserIDHeader": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/parameters/ExpenseID"
          }
        ],
        "responses": {
          "200": {
            "description": "Expense retrieved",
            "schema": {
              "$ref": "#/definitions/ExpenseResponse"
            }
          },
          "400": {
            "description": "Invalid expense ID",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "401": {
            "description": "Missing or invalid X-User-ID header",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "404": {
            "description": "Expense not found",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      },
      "put": {
        "tags": ["Expenses"],
        "summary": "Update an expense",
        "description": "Updates one expense when it belongs to the authenticated user.",
        "operationId": "updateExpense",
        "security": [
          {
            "UserIDHeader": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/parameters/ExpenseID"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ExpenseRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Expense updated successfully",
            "schema": {
              "$ref": "#/definitions/ExpenseResponse"
            }
          },
          "400": {
            "description": "Invalid input",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "401": {
            "description": "Missing or invalid X-User-ID header",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "404": {
            "description": "Expense not found",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "500": {
            "description": "Expense could not be updated",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      },
      "delete": {
        "tags": ["Expenses"],
        "summary": "Delete an expense",
        "description": "Deletes one expense when it belongs to the authenticated user.",
        "operationId": "deleteExpense",
        "security": [
          {
            "UserIDHeader": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/parameters/ExpenseID"
          }
        ],
        "responses": {
          "200": {
            "description": "Expense deleted successfully",
            "schema": {
              "$ref": "#/definitions/EmptyAPIResponse"
            }
          },
          "400": {
            "description": "Invalid expense ID",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "401": {
            "description": "Missing or invalid X-User-ID header",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "404": {
            "description": "Expense not found",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          },
          "500": {
            "description": "Expense could not be deleted",
            "schema": {
              "$ref": "#/definitions/ErrorResponse"
            }
          }
        }
      }
    }
  },
  "parameters": {
    "ExpenseID": {
      "name": "id",
      "in": "path",
      "required": true,
      "type": "integer",
      "minimum": 1,
      "description": "Expense ID"
    }
  },
  "definitions": {
    "RegisterRequest": {
      "type": "object",
      "required": ["name", "email", "password"],
      "properties": {
        "name": {
          "type": "string",
          "example": "Parisa Reza"
        },
        "email": {
          "type": "string",
          "format": "email",
          "example": "parisa@example.com"
        },
        "password": {
          "type": "string",
          "format": "password",
          "minLength": 6,
          "example": "secret123"
        }
      }
    },
    "LoginRequest": {
      "type": "object",
      "required": ["email", "password"],
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "example": "parisa@example.com"
        },
        "password": {
          "type": "string",
          "format": "password",
          "example": "secret123"
        }
      }
    },
    "ExpenseRequest": {
      "type": "object",
      "required": ["title", "amount", "category", "expense_date"],
      "properties": {
        "title": {
          "type": "string",
          "example": "Lunch"
        },
        "amount": {
          "type": "number",
          "format": "double",
          "minimum": 0.01,
          "example": 250.5
        },
        "category": {
          "type": "string",
          "enum": ["Food", "Transport", "Housing", "Entertainment", "Shopping", "Healthcare", "Education", "Utilities", "Other"],
          "example": "Food"
        },
        "note": {
          "type": "string",
          "example": "Team lunch"
        },
        "expense_date": {
          "type": "string",
          "format": "date",
          "example": "2026-06-02"
        }
      }
    },
    "Expense": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "example": 1
        },
        "title": {
          "type": "string",
          "example": "Lunch"
        },
        "amount": {
          "type": "number",
          "format": "double",
          "example": 250.5
        },
        "category": {
          "type": "string",
          "example": "Food"
        },
        "note": {
          "type": "string",
          "example": "Team lunch"
        },
        "expense_date": {
          "type": "string",
          "format": "date",
          "example": "2026-06-02"
        }
      }
    },
    "ExpenseSummary": {
      "type": "object",
      "properties": {
        "date_from": {
          "type": "string",
          "format": "date"
        },
        "date_to": {
          "type": "string",
          "format": "date"
        },
        "total_amount": {
          "type": "number",
          "format": "double"
        },
        "total_count": {
          "type": "integer"
        },
        "category_totals": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "format": "double"
          }
        }
      }
    },
    "LoginData": {
      "type": "object",
      "properties": {
        "user_id": {
          "type": "integer",
          "example": 1
        },
        "name": {
          "type": "string",
          "example": "Parisa Reza"
        },
        "email": {
          "type": "string",
          "format": "email",
          "example": "parisa@example.com"
        }
      }
    },
    "EmptyAPIResponse": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean",
          "example": true
        },
        "message": {
          "type": "string",
          "example": "Server is running"
        },
        "data": {
          "type": "object",
          "x-nullable": true
        }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean",
          "example": false
        },
        "message": {
          "type": "string",
          "example": "Invalid request body"
        },
        "data": {
          "type": "object",
          "x-nullable": true
        }
      }
    },
    "LoginResponse": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean",
          "example": true
        },
        "message": {
          "type": "string",
          "example": "Login successful"
        },
        "data": {
          "$ref": "#/definitions/LoginData"
        }
      }
    },
    "ExpenseResponse": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean",
          "example": true
        },
        "message": {
          "type": "string",
          "example": "Expense retrieved"
        },
        "data": {
          "$ref": "#/definitions/Expense"
        }
      }
    },
    "ExpenseListResponse": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean",
          "example": true
        },
        "message": {
          "type": "string",
          "example": "Expenses retrieved"
        },
        "data": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Expense"
          }
        }
      }
    },
    "ExpenseSummaryResponse": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean",
          "example": true
        },
        "message": {
          "type": "string",
          "example": "Summary generated"
        },
        "data": {
          "$ref": "#/definitions/ExpenseSummary"
        }
      }
    }
  }
}
